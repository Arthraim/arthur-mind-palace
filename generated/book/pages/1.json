    {
      "kind": "book",
      "sourceId": "35005045",
      "title": "夜晚的潜水艇",
      "originalTitle": null,
      "year": "2020",
      "coverPath": "covers/book/35005045.jpg",
      "coverUrl": "https://img1.doubanio.com/view/subject/s/public/s33718940.jpg",
